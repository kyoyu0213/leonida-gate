# Google Analytics 4 の測定ID（任意）。
# 未設定でも既定ID（G-37CH3TFBP4）にフォールバックします。
# 本番ビルド（vite build）時のみ有効。開発（vite dev）では読み込まれません。
VITE_GA_ID=G-37CH3TFBP4

# Supabase 接続情報（任意）。
# anon(publishable) キーは公開前提なので機密ではない。環境変数化は運用面の整理。
# 未設定でもコード内の既定値にフォールバックして動作します。
# 別の Supabase プロジェクトへ移す場合だけ、ここ（または Vercel 等の環境変数）に設定。
# ※ VITE_* はビルド時にバンドルへ埋め込まれるため、設定後は再ビルドが必要。
VITE_SUPABASE_URL=https://uawyuxegcywatkfgyycp.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_56-mcQqzWE-afZce8zFb7Q_qhGAclS3
